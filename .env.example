API_KEY=rapidapi_key_here
QUERY=Kırklareli
QUERY_TYPE=Latest
TWEET_LIMIT=20
POLL_INTERVAL_SECONDS=300
# Optional: query-specific intervals. Example:
# QUERY_SCHEDULE=Kırklareli|5m,Lüleburgaz|10m,Babaeski|15m

TELEGRAM_TOKEN=telegram_bot_token_here
TELEGRAM_CHAT_ID=telegram_chat_id_here

NEWS_LIMIT=10
NEWS_MAX_AGE_HOURS=72
SITEMAP_URLS=https://www.onadimgazetesi.com/sitemap.xml
SITEMAP_MONTHLY_TEMPLATES=https://www.alternatifgazetesi.com/sitemap/sitemap-{YYYY}-{MM}.xml
SITEMAP_MONTH_LOOKBACK=1
# Optional legacy remote list. Leave empty when using SITEMAP_URLS/templates above.
SITEMAP_LIST_URL=
SITEMAP_LIST_FILE=sitemap.txt
SITEMAP_CHECK_SECONDS=600
SITEMAP_REFRESH_SECONDS=86400

HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF=2

# Optional Postgres persistence.
DB_URL=

# Optional API protection for api.py.
API_REQUIRE_TOKEN=true
API_TOKEN=replace_with_strong_api_token

# Optional Cloudflare R2 / S3-compatible state storage.
S3_ENABLE=false
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_BUCKET=
S3_SENT_URLS_KEY=sent_urls.txt
S3_SENT_NEWS_KEY=sent_news.txt
