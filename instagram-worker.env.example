# Copy this file to ~/.config/lastmonitor-instagram/config.env with mode 600.
IG_USERNAME=
# IG_PASSWORD is stored in macOS Keychain by the configure command.
IG_TARGETS=rozmedyahaber|1950,kirklareli_gundem|1950
IG_INTERVAL_JITTER_SECONDS=1050
IG_FETCH_LIMIT=12
IG_SEND_EXISTING=false

CF_INGEST_URL=https://lastmonitor-cloudflare.kerim-yeniyildiz.workers.dev/api/instagram
# CF_INGEST_TOKEN is stored in macOS Keychain by the configure command.

# Runtime data stays outside the repository by default.
IG_RUNTIME_DIR=~/.local/share/lastmonitor-instagram
